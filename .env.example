# Copy to .env in this directory for docker compose
SECRET_KEY_BASE=dev-secret-change-me-in-production
GLEAMHUB_GIT_HOST=localhost

# git-ssh only: API URL when server runs on host (default in compose)
# GLEAMHUB_API_URL=http://host.docker.internal:9999

# Clerk JWKS: single RSA JWK JSON for JWT verification (see README)
CLERK_JWKS='{"use":"sig","kty":"RSA","kid":"YOUR_KEY_ID","alg":"RS256","n":"...","e":"AQAB"}'
