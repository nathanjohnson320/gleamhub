SECRET_KEY_BASE="dev-secret-change-me-in-production"
INTERNAL_API_TOKEN="dev-internal-token-change-me"
PGHOST="localhost"
PGPORT=5432
PGUSER="postgres"
PGDATABASE=gleamhub
PGPASSWORD=postgres
DATABASE_URL="postgres://postgres:postgres@127.0.0.1:5432/gleamhub?sslmode=disable"
CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json
GIT_REPOS_ROOT=./data/repos
# Hostname (and optional port) shown in clone URLs; must match where git-ssh is reachable
GLEAMHUB_GIT_HOST=localhost
# SSH port advertised in clone URLs (default 2222 for local compose; use 22 in production)
GLEAMHUB_GIT_PORT=2222
PORT=9999
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
